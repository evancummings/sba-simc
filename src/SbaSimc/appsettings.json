{
  "SimC": {
    "DockerImage": "simulationcraftorg/simc:latest",
    "Iterations": 1000,
    "MaxParallelism": 4,

    // Confirmed paths for simulationcraftorg/simc:latest as of 2026-05-29 (SimC 1205-01, WoW 12.0.5.67823)
    // The binary lives at /app/SimulationCraft/simc
    // Profiles live at /app/SimulationCraft/profiles/MID1/
    // There is no separate assist_combat file directory — Blizzard's APL is built into the binary.
    // Invoke it with: source=blizzard
    "ContainerProfilesPath": "/app/SimulationCraft/profiles/MID1",

    // Kept for reference but not used at runtime — assist_combat APL is built into the simc binary.
    "ContainerAplPath": "/app/SimulationCraft/profiles"
  },
  "Output": {
    "Directory": "./output"
  }
}
