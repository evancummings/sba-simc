<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SBA SimC — Optimal vs Assisted Highlight vs One Button Rotation</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #0e0e12;
      color: #d4d4d8;
      min-height: 100vh;
      padding: 1.25rem 1rem;
    }

    header {
      max-width: 1400px;
      margin: 0 auto 1rem;
    }

    h1 {
      font-size: 1.4rem;
      font-weight: 700;
      color: #f4f4f5;
      margin-bottom: .3rem;
    }

    .subtitle {
      font-size: .82rem;
      color: #71717a;
    }

    .subtitle a { color: #a1a1aa; }

    /* Summary pills */
    .summary {
      display: flex;
      gap: .75rem;
      flex-wrap: wrap;
      margin: .9rem 0;
    }

    .pill {
      padding: .35rem .85rem;
      border-radius: 9999px;
      font-size: .8rem;
      font-weight: 600;
      letter-spacing: .02em;
    }

    .pill-good     { background: #14532d; color: #86efac; }
    .pill-moderate { background: #713f12; color: #fde68a; }
    .pill-poor     { background: #7f1d1d; color: #fca5a5; }
    .pill-total    { background: #1e1e2e; color: #a1a1aa; border: 1px solid #3f3f46; }

    /* Class filter */
    .filters {
      max-width: 1400px;
      margin: 0 auto 1rem;
      display: flex;
      flex-wrap: wrap;
      gap: .5rem;
      align-items: center;
    }

    .filter-label { font-size: .8rem; color: #71717a; margin-right: .25rem; }

    .filter-btn {
      padding: .3rem .75rem;
      border-radius: 6px;
      border: 1px solid #3f3f46;
      background: #18181b;
      color: #a1a1aa;
      font-size: .8rem;
      cursor: pointer;
      transition: background .15s, color .15s, border-color .15s;
    }

    .filter-btn:hover,
    .filter-btn.active {
      background: #3f3f46;
      color: #f4f4f5;
      border-color: #52525b;
    }

    /* Table */
    .table-wrap {
      max-width: 1400px;
      margin: 0 auto;
      overflow-x: auto;
      border-radius: 10px;
      border: 1px solid #27272a;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: .8rem;
    }

    thead tr {
      background: #18181b;
      border-bottom: 1px solid #27272a;
    }

    th {
      padding: .55rem .7rem;
      text-align: left;
      font-weight: 600;
      color: #a1a1aa;
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }

    th:hover { color: #f4f4f5; }
    th.sorted { color: #f4f4f5; }
    th .sort-arrow { margin-left: .25rem; opacity: .5; font-size: .7rem; }
    th.sorted .sort-arrow { opacity: 1; }

    tbody tr {
      border-bottom: 1px solid #1f1f23;
      transition: background .1s;
    }

    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #18181b; }
    tbody tr.hidden { display: none; }

    td { padding: .45rem .7rem; white-space: nowrap; }

    .class-badge {
      display: inline-block;
      padding: .15rem .55rem;
      border-radius: 5px;
      font-size: .75rem;
      font-weight: 600;
      background: #27272a;
      color: #d4d4d8;
    }

    .dps { font-variant-numeric: tabular-nums; text-align: right; }

    .delta {
      font-variant-numeric: tabular-nums;
      font-weight: 700;
      text-align: right;
      white-space: nowrap;
    }

    .delta-good     { color: #4ade80; }
    .delta-moderate { color: #fbbf24; }
    .delta-poor     { color: #f87171; }

    .delta-bar-cell { width: 80px; padding-left: .3rem; }

    .delta-bar-wrap {
      background: #27272a;
      border-radius: 4px;
      height: 6px;
      width: 64px;
      overflow: hidden;
    }

    .delta-bar {
      height: 100%;
      border-radius: 4px;
      transition: width .3s ease;
    }

    .bar-good     { background: #4ade80; }
    .bar-moderate { background: #fbbf24; }
    .bar-poor     { background: #f87171; }

    footer {
      max-width: 1400px;
      margin: 2rem auto 0;
      font-size: .78rem;
      color: #52525b;
      text-align: center;
    }
  </style>
</head>
<body>

<header>
  <h1>⚔️ SBA SimC — Optimal vs Assisted Highlight vs One Button Rotation</h1>
  <p class="subtitle">
    Comparing the SimulationCraft community-optimal APL against Blizzard's Assisted Highlight (no GCD penalty)
    and One Button Rotation (with GCD penalty), for every class/spec/hero-talent combination.
    SimC version: <strong>{{ simc_version }}</strong> &mdash; {{ iterations | math.format "N0" }} iterations per sim.
  </p>

  <div class="summary">
    <span class="pill pill-total">{{ total_specs }} combinations</span>
    <span class="pill pill-good">✓ {{ good_count }} within 5%</span>
    <span class="pill pill-moderate">~ {{ moderate_count }} within 5–15%</span>
    <span class="pill pill-poor">✗ {{ poor_count }} over 15% loss</span>
  </div>
</header>

<div class="filters">
  <span class="filter-label">Filter by class:</span>
  <button class="filter-btn active" data-class="all" onclick="filterClass(this, 'all')">All</button>
  {{- for cls in classes }}
  <button class="filter-btn" data-class="{{ cls }}" onclick="filterClass(this, '{{ cls }}')">{{ cls }}</button>
  {{- end }}
</div>

<div class="table-wrap">
  <table id="results-table">
    <thead>
      <tr>
        <th onclick="sortTable(0)">Class <span class="sort-arrow">↕</span></th>
        <th onclick="sortTable(1)">Spec <span class="sort-arrow">↕</span></th>
        <th onclick="sortTable(2)">Hero Talent <span class="sort-arrow">↕</span></th>
        <th onclick="sortTable(3)" style="text-align:right">SimC DPS <span class="sort-arrow">↕</span></th>
        <th onclick="sortTable(4)" style="text-align:right" title="Assisted Highlight DPS (Blizzard APL, no GCD penalty)">AH DPS <span class="sort-arrow">↕</span></th>
        <th onclick="sortTable(5)" style="text-align:right" title="One Button DPS (Blizzard APL + GCD penalty)">OB DPS <span class="sort-arrow">↕</span></th>
        <th onclick="sortTable(6)" style="text-align:right" title="Assisted Highlight Delta vs SimC APL">AH Δ <span class="sort-arrow">↕</span></th>
        <th onclick="sortTable(7)" style="text-align:right" title="One Button Delta vs SimC APL">OB Δ <span class="sort-arrow">↕</span></th>
        <th class="delta-bar-cell"></th>
      </tr>
    </thead>
    <tbody>
      {{- for r in results }}
      {{- severity_class = ""
          bar_class = ""
          if r.severity == 0
            severity_class = "delta-good"
            bar_class = "bar-good"
          else if r.severity == 1
            severity_class = "delta-moderate"
            bar_class = "bar-moderate"
          else
            severity_class = "delta-poor"
            bar_class = "bar-poor"
          end
          ob_severity_class = ""
          if r.one_button_severity == 0
            ob_severity_class = "delta-good"
          else if r.one_button_severity == 1
            ob_severity_class = "delta-moderate"
          else
            ob_severity_class = "delta-poor"
          end }}
      {{- bar_width = (r.delta_percent | math.abs) * (100.0 / 30.0) | math.round
          bar_width = bar_width > 100 ? 100 : bar_width }}
      <tr data-class="{{ r.spec.class }}">
        <td><span class="class-badge">{{ r.spec.class }}</span></td>
        <td>{{ r.spec.spec }}</td>
        <td>{{ r.spec.hero_talent }}</td>
        <td class="dps" data-val="{{ r.optimal_dps | math.round }}">{{ r.optimal_dps | math.round }}</td>
        <td class="dps" data-val="{{ r.assisted_highlight_dps | math.round }}">{{ r.assisted_highlight_dps | math.round }}</td>
        <td class="dps" data-val="{{ r.one_button_dps | math.round }}">{{ r.one_button_dps | math.round }}</td>
        <td class="delta {{ severity_class }}" data-val="{{ r.delta_percent }}">{{ r.delta_formatted }}</td>
        <td class="delta {{ ob_severity_class }}" data-val="{{ r.one_button_delta_percent }}">{{ r.one_button_delta_formatted }}</td>
        <td class="delta-bar-cell">
          <div class="delta-bar-wrap">
            <div class="delta-bar {{ bar_class }}" style="width: {{ bar_width }}%"></div>
          </div>
        </td>
      </tr>
      {{- end }}
    </tbody>
  </table>
</div>

<footer>
  Generated {{ generated_at }} &mdash;
  <a href="https://github.com/simulationcraft/simc" style="color:#52525b">SimulationCraft</a> &mdash;
  <a href="https://github.com/ecummings/sba-simc" style="color:#52525b">Source</a>
</footer>

<script>
  // Official WoW class colors
  const CLASS_COLORS = {
    'Death Knight': '#C41E3A',
    'Demon Hunter': '#A330C9',
    'Druid':        '#FF7C0A',
    'Evoker':       '#33937F',
    'Hunter':       '#AAD372',
    'Mage':         '#3FC7EB',
    'Monk':         '#00FF98',
    'Paladin':      '#F48CBA',
    'Priest':       '#F0EDD4',
    'Rogue':        '#FFF468',
    'Shaman':       '#0070DD',
    'Warlock':      '#8788EE',
    'Warrior':      '#C69B3A',
  };

  function hexToRgb(hex) {
    return {
      r: parseInt(hex.slice(1, 3), 16),
      g: parseInt(hex.slice(3, 5), 16),
      b: parseInt(hex.slice(5, 7), 16),
    };
  }

  // Number formatter
  const fmt = new Intl.NumberFormat('en-US');

  // Humanize numbers already set as text — re-format after Scriban renders
  document.querySelectorAll('td.dps').forEach(td => {
    const v = parseFloat(td.dataset.val);
    if (!isNaN(v)) td.textContent = fmt.format(Math.round(v));
  });

  // Apply class colors to table badges
  document.querySelectorAll('.class-badge').forEach(badge => {
    const color = CLASS_COLORS[badge.textContent.trim()];
    if (!color) return;
    const { r, g, b } = hexToRgb(color);
    badge.style.color = color;
    badge.style.background = `rgba(${r},${g},${b},0.15)`;
  });

  // Apply class colors to filter buttons (idle state)
  function applyIdleStyle(btn) {
    const color = CLASS_COLORS[btn.dataset.class];
    if (!color) { btn.style.color = ''; btn.style.borderColor = ''; btn.style.background = ''; return; }
    btn.style.color = color;
    btn.style.borderColor = color + '55';
    btn.style.background = '';
  }

  function applyActiveStyle(btn) {
    const color = CLASS_COLORS[btn.dataset.class];
    if (!color) { btn.style.color = ''; btn.style.borderColor = ''; btn.style.background = ''; return; }
    const { r, g, b } = hexToRgb(color);
    btn.style.color = color;
    btn.style.borderColor = color;
    btn.style.background = `rgba(${r},${g},${b},0.18)`;
  }

  document.querySelectorAll('.filter-btn[data-class]').forEach(btn => {
    applyIdleStyle(btn);
  });

  // Class filter
  let activeClass = 'all';
  function filterClass(btn, cls) {
    activeClass = cls;
    document.querySelectorAll('.filter-btn').forEach(b => {
      b.classList.remove('active');
      applyIdleStyle(b);
    });
    btn.classList.add('active');
    applyActiveStyle(btn);
    document.querySelectorAll('#results-table tbody tr').forEach(row => {
      row.classList.toggle('hidden', cls !== 'all' && row.dataset.class !== cls);
    });
  }

  // Sort
  let sortCol = 6, sortAsc = true; // pre-set so first sortTable(6) call flips to descending
  function sortTable(col) {
    const table = document.getElementById('results-table');
    const tbody = table.querySelector('tbody');
    const rows  = Array.from(tbody.querySelectorAll('tr'));

    if (sortCol === col) sortAsc = !sortAsc;
    else { sortCol = col; sortAsc = true; }

    rows.sort((a, b) => {
      const aCell = a.cells[col];
      const bCell = b.cells[col];
      const aVal  = aCell.dataset.val ?? aCell.textContent.trim();
      const bVal  = bCell.dataset.val ?? bCell.textContent.trim();
      const aNum  = parseFloat(aVal);
      const bNum  = parseFloat(bVal);
      const cmp   = isNaN(aNum) || isNaN(bNum)
        ? aVal.localeCompare(bVal)
        : aNum - bNum;
      return sortAsc ? cmp : -cmp;
    });

    rows.forEach(r => tbody.appendChild(r));
    filterClass(document.querySelector(`.filter-btn[data-class="${activeClass}"]`), activeClass);

    // Update arrow indicators
    document.querySelectorAll('th').forEach((th, i) => {
      th.classList.toggle('sorted', i === col);
      const arrow = th.querySelector('.sort-arrow');
      if (arrow) arrow.textContent = i === col ? (sortAsc ? '↑' : '↓') : '↕';
    });
  }

  // Default sort: AH delta descending (closest to optimal at top)
  sortTable(6);
</script>
</body>
</html>
